[push]
	default = simple
	autoSetupRemote = true
[pull]
	rebase = true
[credential]
	helper = store
[color]
	ui = true
[column]
	ui = auto
[alias]
	co = checkout
	mg = merge --allow-unrelated-histories
	ci = commit --allow-empty-message
	st = status -sb
	dup = clone --depth=1 --no-single-branch --recursive --shallow-submodules
	graph = log --all --graph --abbrev-commit --pretty=tformat:'%>|(15)%Cred%h %C(auto)%d%Creset %<|(66,trunc)%s %Cgreen%>(7)%ar %Cblue%an'
	last = log -1 HEAD
[core]
	editor = vim
	eol = lf
	safecrlf = warn
	autocrlf = input
	fscache = true
	excludesfile = ~/.gitignore
	pager = delta
[interactive]
	diffFilter = delta --color-only
[rerere]
	enabled = true
	autoupdate = true
[merge]
	renormalize = true
	conflictStyle = zdiff3
[rebase]
	autoSquash = true
	autoStash = true
	updateRefs = true
[help]
	autoCorrect = prompt
[gpg]
	program = gpg2
[http]
	proxy = http://127.0.0.1:7890
[https]
	proxy = http://127.0.0.1:7890
[diff]
	mnemonicPrefix = true
	renames = true
[delta]
	navigate = true
	line-numbers = true
	hyperlinks = true
[branch]
	sort = -committerdate
[tag]
	sort = version:refname
[init]
	defaultBranch = main
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
